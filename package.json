{
  "name": "@digitalshare/medianode",
  "version": "0.1.0",
  "description": "CLI agent for media production workflows. Drives mainstream LLMs and operates local media-studio CLIs (default: SceneSpark).",
  "type": "module",
  "bin": {
    "medianode": "dist/cli/index.js"
  },
  "main": "dist/cli/index.js",
  "files": [
    "dist",
    "skills-bundled",
    "install.sh",
    "README.md",
    "PLAN.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.77.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "react": "^18.3.1",
    "marked": "^14.1.4",
    "marked-terminal": "^7.2.1",
    "cli-highlight": "^2.1.11",
    "dotenv": "^16.4.7",
    "zod": "^3.23.8",
    "execa": "^9.5.2",
    "undici": "^7.0.0",
    "simple-git": "^3.27.0",
    "pino": "^9.5.0",
    "yaml": "^2.6.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/marked-terminal": "^6.1.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalshare/medianode.git"
  },
  "license": "MIT",
  "keywords": ["cli", "agent", "llm", "media", "scenespark", "video", "audio"],
  "publishConfig": {
    "access": "public"
  }
}
